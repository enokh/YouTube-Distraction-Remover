{
  "manifest_version": 3,
  "name": "YouTube Distraction Remover",
  "version": "1.0.0",
  "description": "Removes Shorts, watch-page recommendations, and homepage algorithm feed.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
